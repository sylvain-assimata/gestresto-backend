# URL de connexion PostgreSQL (Railway te la fournit automatiquement)
DATABASE_URL="postgresql://user:password@host:5432/gestresto"

# Clé secrète pour signer les tokens JWT — change-la en production
JWT_SECRET="remplace-moi-par-une-longue-chaine-aleatoire"

# Port d'écoute du serveur (Railway le définit automatiquement)
PORT=3001
